import math

xC, yC = map(float, input("Nhap toa do tam C(xC, yC): ").split())
R = float(input("Nhap ban kinh R: "))
xM, yM = map(float, input("Nhap toa do M(xM, yM): ").split())

d = math.sqrt((xM - xC)**2 + (yM - yC)**2)

if d < R:
    print("M nam trong C()")
elif d == R:
    print("M nam tren C()")
else:
    print("M nam ngoai C()")
