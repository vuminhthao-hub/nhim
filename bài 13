d,m,y = map(int,input("Nhap ngay, thang va nam: ").split())

nhuan = (y%4==0 and y%100!=0) or y%400==0
ngay_thang = [31,29 if nhuan else 28,31,30,31,30,31,31,30,31,30,31]
if 1<=m<=12 and 1<=d<=ngay_thang[m-1]:
    print("Hop le")
    a = (14-m)//12
    y2 = y - a
    m2 = m + 12*a - 2
    w = (d + y2 + y2//4 - y2//100 + y2//400 + (31*m2)//12) % 7
    thu = ["Chu nhat","Thu 2","Thu 3","Thu 4","Thu 5","Thu 6","Thu 7"]
    print(thu[w])
else:
    print("Khong hop le")
